{
  "name": "redact-digital",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json",
    "lint": "prettier --check src/ && oxlint . --type-aware --quiet && cspell . --no-progress --unique",
    "format": "prettier --write src/",
    "lint:fix": "oxlint . --type-aware --fix --quiet"
  },
  "dependencies": {
    "lucide-vue-next": "^1.0.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "cspell": "^8.0.0",
    "oxlint": "^1.0.0",
    "oxlint-tsgolint": "^0.21.1",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.7.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.2.0"
  }
}
