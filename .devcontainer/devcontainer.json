{
  "name": "redact-digital",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  // * Fix docker socket perms for host daemon access
  // * Symlink .claude.json from persistent volume (can't mount volumes to files, only dirs)
  "postStartCommand": "sudo chmod 666 /var/run/docker.sock; sudo chown -R ubuntu:ubuntu /home/ubuntu/.claude-persist /home/ubuntu/.claude-history-persist /home/ubuntu/.claude/projects /home/ubuntu/.claude/sessions; [ ! -f /home/ubuntu/.claude-persist/.claude.json ] && echo '{}' > /home/ubuntu/.claude-persist/.claude.json; ln -sf /home/ubuntu/.claude-persist/.claude.json /home/ubuntu/.claude.json; [ ! -f /home/ubuntu/.claude-history-persist/history.jsonl ] && echo '' > /home/ubuntu/.claude-history-persist/history.jsonl; ln -sf /home/ubuntu/.claude-history-persist/history.jsonl /home/ubuntu/.claude/history.jsonl",
  "mounts": [
    // Claude files from local machine
    // IMPORTANT: Single-FILE bind mounts below are marked `readonly` to prevent
    // atomic-write sever. If Claude Code inside the container writes to these
    // files (e.g. toggling skipDangerousMode, changing model, etc.), the
    // write-via-rename detaches the mount — the new file lands on the
    // container overlay FS and the host file is never updated. Symptom: host
    // shows full config but `stat` inside container shows `Links: 0` and a
    // tiny stub file. Result: ALL hooks go silently dark.
    // Directory mounts (hooks, skills, memory, etc.) are safe because the
    // mount point is the directory itself; files inside can be rewritten
    // freely. Only individual-file mounts need this protection.
    // Edit these files on the HOST (~/.claude/) — changes propagate live.
    "source=${localEnv:HOME}/.claude/CLAUDE.md,target=/home/ubuntu/.claude/CLAUDE.md,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/settings.json,target=/home/ubuntu/.claude/settings.json,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/statusline-command.sh,target=/home/ubuntu/.claude/statusline-command.sh,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/hooks,target=/home/ubuntu/.claude/hooks,type=bind",
    "source=${localEnv:HOME}/.claude/skills,target=/home/ubuntu/.claude/skills,type=bind",
    "source=${localEnv:HOME}/.claude/commands,target=/home/ubuntu/.claude/commands,type=bind",
    "source=${localEnv:HOME}/.claude/rules,target=/home/ubuntu/.claude/rules,type=bind",
    "source=${localEnv:HOME}/.claude/agents,target=/home/ubuntu/.claude/agents,type=bind",
    "source=${localEnv:HOME}/.claude/templates,target=/home/ubuntu/.claude/templates,type=bind",
    "source=${localEnv:HOME}/.claude/docker,target=/home/ubuntu/.claude/docker,type=bind",
    "source=${localEnv:HOME}/.claude/docs,target=/home/ubuntu/.claude/docs,type=bind",
    "source=${localEnv:HOME}/.claude/memory,target=/home/ubuntu/.claude/memory,type=bind",
    "source=${localEnv:HOME}/.claude/.credentials.json,target=/home/ubuntu/.claude/.credentials.json,type=bind",
    "source=${localEnv:HOME}/.claude/plugins,target=/home/ubuntu/.claude/plugins,type=bind",
    // Docker socket
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    // Persistent container-only storage
    "source=redact-digital-claude-sessions,target=/home/ubuntu/.claude/sessions,type=volume",
    "source=redact-digital-claude-projects,target=/home/ubuntu/.claude/projects,type=volume",
    // history.jsonl is a FILE, not a dir — same workaround as .claude.json:
    // mount volume to staging dir, symlink the file in postStartCommand
    "source=redact-digital-claude-history,target=/home/ubuntu/.claude-history-persist,type=volume",
    // Persistent state for .claude.json, requires postStartCommand to symlink to .claude.json because can't mount volumes to files, only dirs
    "source=redact-digital-claude-state,target=/home/ubuntu/.claude-persist,type=volume",
    // Portable aliases (docker, git, claude shortcuts — lives in repo, survives WSL reinstalls)
    "source=${localWorkspaceFolder}/.devcontainer/bash_aliases,target=/home/ubuntu/.bash_aliases,type=bind,readonly",
    // Git config from local machine
    "source=${localEnv:HOME}/.gitconfig,target=/home/ubuntu/.gitconfig,type=bind",
    // SSH from local machine
    "source=${localEnv:HOME}/.ssh,target=/home/ubuntu/.ssh,type=bind"
  ],
  // Docker Compose runs on the HOST daemon (via socket mount), so volume
  // mounts need the HOST path, not the devcontainer path. This env var
  // passes the host-side workspace folder into the container so
  // docker-compose.yml can use it: ${HOST_PROJECT_PATH:-.}:/app
  "remoteEnv": {
    "HOST_PROJECT_PATH": "${localWorkspaceFolder}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "oxc.oxc-vscode",
        "ms-vscode.vscode-typescript-next",
        "edwinhuish.better-comments-next",
        "chunsen.bracket-select",
        "streetsidesoftware.code-spell-checker",
        "codeandstuff.package-json-upgrade",
        "esbenp.prettier-vscode",
        "yoavbls.pretty-ts-errors",
        "bradlc.vscode-tailwindcss",
        "vue.volar",
        "mikestead.dotenv",
        "anthropic.claude-code"
      ]
    }
  }
}
